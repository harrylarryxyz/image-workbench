# API
API_PORT=3100
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://image:image@localhost:5432/image_workbench
REDIS_HOST=localhost
REDIS_PORT=6379
STORAGE_BACKEND=local
STORAGE_DIR=./data/uploads
STORAGE_BUCKET=image-workbench
STORAGE_PUBLIC_BASE_URL=
PROVIDER_SECRET_KEY=64_HEX_CHARS_FOR_AES_256_GCM
WORKBENCH_ADMIN_TOKEN=optional_admin_token_for_api
WORKBENCH_RATE_LIMIT_PER_MINUTE=240
BACKUP_DIR=/opt/image-workbench/backups/data
BACKUP_MANIFEST_PATH=/opt/image-workbench/backups/data/latest-manifest.json
AGENT_LLM_BASE_URL=
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=gpt-4.1-mini
NEXT_PUBLIC_WORKBENCH_TOKEN=optional_session_token_for_internal_browser
NEXT_PUBLIC_WORKSPACE_ID=default

# Initial environment provider fallback
IMAGE_API_BASE=https://api.example.com/v1
IMAGE_API_KEY=YOUR_PROVIDER_API_KEY
IMAGE_MODEL=gpt-image-2

S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
TARGET_STORAGE_BACKEND=s3