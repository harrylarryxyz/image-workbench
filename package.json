{
  "name": "image-workbench",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @image-workbench/api prisma:generate",
    "db:migrate": "pnpm --filter @image-workbench/api prisma:migrate",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "dev:api": "pnpm --filter @image-workbench/api dev",
    "dev:web": "pnpm --filter @image-workbench/web dev",
    "backup": "./scripts/backup-image-workbench.sh",
    "backup:rabisu": "./scripts/backup-rabisu.sh",
    "restore:rabisu": "./scripts/restore-rabisu-backup.sh",
    "rollback:rabisu": "./scripts/rollback-rabisu.sh",
    "deploy:rabisu": "./scripts/deploy-rabisu.sh",
    "prune:rabisu-releases": "./scripts/prune-rabisu-releases.sh",
    "assets:audit": "./scripts/audit-local-assets.sh",
    "assets:migrate-remote": "pnpm --filter @image-workbench/api exec ts-node ../../scripts/migrate-local-assets-to-remote.ts",
    "assets:cleanup-orphans": "pnpm --filter @image-workbench/api exec ts-node ../../scripts/cleanup-orphan-assets.ts"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "latest",
    "prettier": "latest"
  }
}
