generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderType {
  OPENAI_COMPATIBLE
  FAL
  CUSTOM_HTTP
}

enum ApiMode {
  AUTO
  IMAGES
  RESPONSES
}

enum TaskStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  RETRYING
}

model ProviderProfile {
  id              String   @id @default(cuid())
  name            String
  type            ProviderType @default(OPENAI_COMPATIBLE)
  baseUrl         String
  apiKeyEncrypted String
  defaultModel    String
  apiMode         ApiMode @default(AUTO)
  enabled         Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tasks           GenerationTask[]
}

model GenerationTask {
  id              String @id @default(cuid())
  type            String @default("image.generate")
  status          TaskStatus @default(QUEUED)
  providerId      String?
  provider        ProviderProfile? @relation(fields: [providerId], references: [id])
  model           String
  prompt          String
  paramsJson      Json
  routeJson       Json?
  diagnosticsJson Json?
  errorCode       String?
  errorMessage    String?
  elapsedMs       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  images          ImageAsset[]
}

model ImageAsset {
  id             String @id @default(cuid())
  taskId         String
  task           GenerationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  storageKey     String
  thumbnailKey   String?
  width          Int?
  height         Int?
  format         String
  sizeBytes      Int
  sha256         String
  prompt         String?
  revisedPrompt  String?
  metadataJson   Json?
  createdAt      DateTime @default(now())
}

model CanvasProject {
  id          String @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  nodes       CanvasNode[]
  edges       CanvasEdge[]
}

model CanvasNode {
  id        String @id @default(cuid())
  projectId String
  project   CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  positionX Float
  positionY Float
  dataJson  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CanvasEdge {
  id           String @id @default(cuid())
  projectId    String
  project      CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceNodeId String
  targetNodeId String
  type         String
  dataJson     Json?
}

model PromptPreset {
  id        String @id @default(cuid())
  title     String
  content   String
  tags      String[]
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
