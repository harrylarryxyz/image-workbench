generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderType {
  OPENAI_COMPATIBLE
  FAL
  CUSTOM_HTTP
}

enum ApiMode {
  AUTO
  IMAGES
  RESPONSES
}

enum TaskStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  RETRYING
}

model Workspace {
  id        String @id @default(cuid())
  slug      String @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     UserSession[]
  providers ProviderProfile[]
  tasks     GenerationTask[]
  assets    ImageAsset[]
  prompts   PromptPreset[]
  canvases  CanvasProject[]
}

model UserSession {
  id          String @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tokenHash   String @unique
  label       String?
  role        String @default("admin")
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime?
}

model ProviderProfile {
  id              String   @id @default(cuid())
  name            String
  type            ProviderType @default(OPENAI_COMPATIBLE)
  baseUrl         String
  apiKeyEncrypted String
  defaultModel    String
  apiMode         ApiMode @default(AUTO)
  enabled         Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tasks           GenerationTask[]
  workspaceId     String?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  targetType String?
  targetId   String?
  metadataJson Json?
  createdAt DateTime @default(now())
}

model GenerationTask {
  id              String @id @default(cuid())
  type            String @default("image.generate")
  status          TaskStatus @default(QUEUED)
  providerId      String?
  provider        ProviderProfile? @relation(fields: [providerId], references: [id])
  model           String
  prompt          String
  paramsJson      Json
  routeJson       Json?
  diagnosticsJson Json?
  errorCode       String?
  errorMessage    String?
  elapsedMs       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  images          ImageAsset[]
  workspaceId     String?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id])
  estimatedCostUsd Decimal? @db.Decimal(10, 6)
}

model ImageAsset {
  id             String @id @default(cuid())
  taskId         String
  task           GenerationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  storageKey     String
  thumbnailKey   String?
  width          Int?
  height         Int?
  format         String
  sizeBytes      Int
  sha256         String
  prompt         String?
  revisedPrompt  String?
  metadataJson   Json?
  createdAt      DateTime @default(now())
  workspaceId    String?
  workspace      Workspace? @relation(fields: [workspaceId], references: [id])
  favorite       Boolean @default(false)
  rating         Int?
  tags           String[]
}

model CanvasProject {
  id          String @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  nodes       CanvasNode[]
  edges       CanvasEdge[]
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  snapshots   CanvasSnapshot[]
  isTemplate  Boolean @default(false)
}

model CanvasNode {
  id        String @id @default(cuid())
  projectId String
  project   CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  positionX Float
  positionY Float
  dataJson  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CanvasEdge {
  id           String @id @default(cuid())
  projectId    String
  project      CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceNodeId String
  targetNodeId String
  type         String
  dataJson     Json?
}

model PromptPreset {
  id        String @id @default(cuid())
  title     String
  content   String
  tags      String[]
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  versions  PromptVersion[]
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
}

model PromptVersion {
  id        String @id @default(cuid())
  promptId  String
  prompt    PromptPreset @relation(fields: [promptId], references: [id], onDelete: Cascade)
  version   Int
  title     String
  content   String
  tags      String[]
  createdAt DateTime @default(now())
}


model CanvasSnapshot {
  id        String @id @default(cuid())
  projectId String
  project   CanvasProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String?
  nodesJson Json
  edgesJson Json
  createdAt DateTime @default(now())
}
