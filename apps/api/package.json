{
  "name": "@image-workbench/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch --entryFile apps/api/src/main",
    "build": "nest build",
    "start": "node dist/apps/api/src/main.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --dir src",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "provider-secrets:migrate": "ts-node src/providers/provider-secret-migration.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1055.0",
    "@aws-sdk/s3-request-presigner": "^3.1055.0",
    "@image-workbench/image-utils": "workspace:*",
    "@image-workbench/provider-sdk": "workspace:*",
    "@image-workbench/shared": "workspace:*",
    "@nestjs/bullmq": "latest",
    "@nestjs/common": "latest",
    "@nestjs/config": "latest",
    "@nestjs/core": "latest",
    "@nestjs/platform-express": "latest",
    "@prisma/client": "^6.19.3",
    "archiver": "^8.0.0",
    "bullmq": "latest",
    "ioredis": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest",
    "sharp": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@nestjs/cli": "latest",
    "@nestjs/schematics": "latest",
    "@nestjs/testing": "latest",
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "latest",
    "prisma": "^6.19.3",
    "ts-loader": "latest",
    "ts-node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
